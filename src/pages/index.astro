---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/home/Hero.astro';
import CoreValues from '../components/home/CoreValues.astro';
import OurStory from '../components/home/OurStory.astro';
import AreasOfFocus from '../components/home/AreasOfFocus.astro';
import Roadmap from '../components/home/Roadmap.astro';
import Founders from '../components/home/Founders.astro';
import GetInvolved from '../components/home/GetInvolved.astro';
---

<MainLayout
  title="Home"
  description="Kailash Research Foundation bridges research and community challenges, focusing on policy research, human rights, women's empowerment, health access, and education to create inclusive, resilient systems."
>
  <!-- Additional structured data for homepage -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://kailashresearch.org//#website",
          "url": "https://kailashresearch.org//",
          "name": "Kailash Research Foundation",
          "description": "Where Research Meets Human Resolve",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://kailashresearch.org//search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "WebPage",
          "@id": "https://kailashresearch.org//#webpage",
          "url": "https://kailashresearch.org//",
          "name": "Home | Kailash Research Foundation",
          "isPartOf": {
            "@id": "https://kailashresearch.org//#website"
          },
          "about": {
            "@id": "https://kailashresearch.org//#organization"
          },
          "description": "Kailash Research Foundation bridges research and community challenges, focusing on policy research, human rights, women's empowerment, health access, and education to create inclusive, resilient systems."
        }
      ]
    }
  </script>

    <div class="flex justify-center bg-primary-50">
        <img src="/logo.svg" alt="Kailash Research Foundation Logo" class="w-40 -my-4 md:w-[17vw] md:my-[-1.7vw]" />
    </div>
  <Hero />

  <CoreValues />

  <OurStory />

  <AreasOfFocus />

  <Roadmap />

  <Founders />

  <GetInvolved />
</MainLayout>
