<!-- Core Values Section -->
<section id="values" class="py-16 bg-primary-50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-8">Core Values</h2>
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-wrap justify-center gap-4">
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Inclusivity</span>
          <span class="text-sm text-center">Every voice matters</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Representation</span>
          <span class="text-sm text-center">Diverse communities at the table</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Equity</span>
          <span class="text-sm text-center">Fair opportunities for all</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Public-Centric</span>
          <span class="text-sm text-center">People's needs first</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Understanding Heterogeneity</span>
          <span class="text-sm text-center">Embracing diversity</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Growth & Adaptability</span>
          <span class="text-sm text-center">Evolving with change</span>
        </div>
        <div class="inline-flex flex-col items-center bg-white border-2 border-primary-400 rounded-full px-6 py-3">
          <span class="font-bold text-primary-600">Wisdom & Fearlessness</span>
          <span class="text-sm text-center">Courage with knowledge</span>
        </div>
      </div>
    </div>
  </div>
  </section>
