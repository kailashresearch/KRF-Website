<!-- Core Values Section -->
<section id="values" class="py-16 bg-primary-50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-8">Core Values</h2>

    <div class="max-w-6xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Inclusivity</h3>
                <p>Every voice matters, regardless of background</p>
            </div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Representation</h3>
                <p>Ensuring diverse communities have a seat at the table</p>
            </div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Equity</h3>
                <p>Fairness in opportunities and access to resources</p>
            </div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Public-Centric</h3>
                <p>People’s needs at the heart of every decision</p>
            </div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Understanding Heterogeneity</h3>
                <p>Recognising the complexity and diversity within communities</p>
            </div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Growth & Adaptability</h3>
                <p>Evolving with changing realities</p>
            </div>
            <div class="hidden md:block"></div>
            <div class="bg-white ring-1 ring-primary-500 p-6 rounded-lg text-center">
                <h3 class="text-xl font-bold mb-3 text-primary-600">Wisdom & Fearlessness</h3>
                <p>Acting with courage, backed by knowledge</p>
            </div>
        </div>
    </div>
  </div>
  </section>
