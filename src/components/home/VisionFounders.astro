---

<!-- Our Vision & Founders Section -->
<section id="founders" class="py-16">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">Our Vision</h2>

    <div class="max-w-4xl mx-auto mb-16">
      <div class="bg-white p-8 rounded-lg shadow-md border-l-4 border-primary-800">
        <p class="text-2xl font-light text-center mb-8 leading-relaxed">
          "At KRF, we believe that <span class="font-medium text-primary-600">transformation is strongest when it is grounded in both insight and action</span>. Our mission is to bridge the gap between the realities communities face and the solutions they deserve, creating systems that are as resilient as they are inclusive."
        </p>

        <p class="text-xl text-center">
          KRF is our shared platform to unite research, policy, and community action. We see it as a space where ideas evolve into tangible, lasting transformation. If our vision resonates with you, we welcome you to connect, collaborate, and grow alongside us.
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto">
      <h3 class="text-xl font-bold text-center mb-6 text-primary-600">Meet Our Founders</h3>
      <div class="grid grid-cols-2 md:grid-cols-2 gap-8" id="founder-grid">
        <button type="button" class="group active focus:outline-none cursor-pointer hover:scale-120 transition-transform" data-founder-index="0" aria-label="Select Raveena Palli">
          <div class="mb-4 flex justify-center object-center">
            <img src="/KRF-Website/Raveena.jpeg" alt="Raveena Palli" class="rounded-full shadow-md w-64 object-cover aspect-square transition ring-2 ring-transparent group-[.active]:ring-primary-600 group-[.active]:opacity-100 opacity-70 group-hover:ring-primary-600" />
          </div>
        </button>
        <button type="button" class="group focus:outline-none cursor-pointer hover:scale-120 transition-transform" data-founder-index="1" aria-label="Select Lakshya N. Palli">
          <div class="mb-4 flex justify-center object-center">
            <img src="/KRF-Website/Lakshya.jpeg" alt="Lakshya N. Palli" class="rounded-full shadow-md w-64 object-cover aspect-square transition ring-2 ring-transparent group-[.active]:ring-primary-600 group-[.active]:opacity-100 opacity-70 group-hover:ring-primary-600" />
          </div>
        </button>
      </div>

      <section aria-region="founder-details" class="mt-8" id="founder-details">
      </section>
      <script>
        const founders = [
          {
            name: 'Raveena Palli',
            paragraphs: [
              "Worked across 250+ districts in India, she has led initiatives in policy research, electoral strategy, and grassroots development. Her work spans designing evidence-based solutions in health access, education, women's empowerment, and human rights.",
              'Currently serving as an election advisor— always recognising that these challenges are deeply interconnected. She brings the perspective of someone who has worked in both the halls of policy and on the ground with communities, ensuring that every solution we design is practical, inclusive, and built to last.'
            ]
          },
          {
            name: 'Lakshya N. Palli',
            paragraphs: [
              'An IIT graduate and accomplished RTL designer with expertise in design synthesis, modem, and Wi-Fi technologies. A star scholar and sports enthusiast, Lakshya is driven by building businesses that thrive in partnership with the communities they serve.'
            ]
          }
        ];

        const detailsEl = document.getElementById('founder-details');
        const gridEl = document.getElementById('founder-grid');

        function renderDetails(index: number) {
          const f = founders[index] || founders[0];
          const paragraphsHtml = f.paragraphs
            .map((t, i) => `<p class="text-sm md:text-lg text-center text-gray-600${i === 0 ? ' mb-4' : ''}">${t}</p>`)
            .join('');

          if (!detailsEl || !gridEl) {
            return;
          }

          detailsEl.innerHTML = `
            <h4 class="text-lg font-bold mb-2 text-gray-600 text-center">${f.name}</h4>
            ${paragraphsHtml}
          `;
          [...gridEl.querySelectorAll('button[data-founder-index]')].forEach(btn => {
            const selected = String(index) === btn.getAttribute('data-founder-index');
            btn.setAttribute('aria-selected', selected ? 'true' : 'false');

          });
        }

        function focusFounder(e: Event) {
            if (!e.target) {
              return;
            }
            const btn = (e.target as HTMLElement).closest('button[data-founder-index]');
            if (!btn) return;

            const allButtons = document.querySelectorAll('#founders .group.active');

            for (const button of allButtons) {
              button.classList.remove('active');
            }

            btn.classList.add('active')

            const idx = parseInt(btn.getAttribute('data-founder-index') ?? '0') || 0;
            renderDetails(idx);
        }

        gridEl?.addEventListener('click', focusFounder);
        gridEl?.addEventListener('mouseover', focusFounder);

        renderDetails(0);
      </script>
    </div>
  </div>
</section>
