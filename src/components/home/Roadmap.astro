---
import TwelveMonthCard from "./TwelveMonthCard.astro";
import FiveYearCard from "./FiveYearCard.astro";---

<!-- Roadmap & Plans Section -->
<section id="roadmap" class="py-16 bg-primary-50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-semibold text-center mb-12">Roadmap & Plans</h2>

    <!-- Timeline Container -->
    <div class="max-w-5xl mx-auto relative">

      <!-- Timeline Line -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-1 bg-primary-300 transform -translate-x-1/2"></div>

      <!-- Next 12 Months Section -->
      <div class="mb-16 relative">
        <div class="md:flex items-center mb-8">
          <div class="md:w-1/2 pr-8 md:text-right mb-4 md:mb-0">
            <h3 class="text-2xl font-semibold text-primary-600">Next 12 Months</h3>
            <p class="text-gray-600">Building strong foundations</p>
          </div>
          <div class="hidden md:flex justify-center items-center">
            <div class="w-12 h-12 rounded-full bg-textcolor-950 border-4 border-white shadow-lg flex items-center justify-center text-white font-semibold">
              1
            </div>
          </div>
          <div class="md:w-1/2 md:pl-8">
            <p class="text-gray-800">
              In its first year, KRF will focus on building strong roots while taking decisive early steps.
            </p>
          </div>
        </div>

        <!-- 12 Month Milestones -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
          <TwelveMonthCard index="1" title="Community Outreach">
              Conduct outreach in selected districts to understand local realities firsthand.
          </TwelveMonthCard>

          <div class="hidden md:block"></div>
          <div class="hidden md:block"></div>

          <TwelveMonthCard index="2" title="Women's Safety">
              Design practical, community-driven solutions to improve women's safety.
          </TwelveMonthCard>

          <TwelveMonthCard index="3" title="Education Initiatives">
              Host gatherings for children and youth aimed at bridging critical education gaps.
          </TwelveMonthCard>

          <div class="hidden md:block"></div>
          <div class="hidden md:block"></div>

          <TwelveMonthCard index="4" title="Network Building">
              Form networks with relevant government channels and civic bodies to accelerate impact.
          </TwelveMonthCard>

        </div>
      </div>

      <!-- 3-5 Year Vision Section -->
      <div class="relative">
        <div class="md:flex items-center mb-8">
          <div class="md:w-1/2 pr-8 md:text-right mb-4 md:mb-0">
            <h3 class="text-2xl font-semibold text-primary-600">3–5 Year Vision</h3>
            <p class="text-gray-600">Expanding our impact</p>
          </div>
          <div class="hidden md:flex justify-center items-center">
            <div class="w-12 h-12 rounded-full bg-textcolor-950 border-4 border-white shadow-lg flex items-center justify-center text-white font-semibold">
              2
            </div>
          </div>
          <div class="md:w-1/2 md:pl-8">
            <p class="text-gray-800">
              Our goal is to establish KRF as a respected think tank with the capacity to deliver on-ground reforms.
            </p>
          </div>
        </div>

        <!-- Long-term Vision Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
          <FiveYearCard title="Research Excellence" description="Developing high-quality research and policy recommendations that address complex social issues.">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
          </FiveYearCard>

          <FiveYearCard title="Community Engagement" description="Combining rigorous analysis with active community engagement, ensuring our work is both deeply informed and immediately relevant.">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
          </FiveYearCard>

          <FiveYearCard title="Institutional Partnerships" description="Directly implementing solutions in partnership with communities, institutions, and government bodies.">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
          </FiveYearCard>

          <FiveYearCard title="Sustainable Impact" description="Ensuring our ideas don't just live on paper — they live in people's lives and create lasting positive change.">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
          </FiveYearCard>

        </div>
      </div>
    </div>
  </div>
</section>
