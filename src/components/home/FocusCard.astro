---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="basis-full md:basis-1/2 lg:basis-1/3 p-2 text-center">
    <div class="bg-white p-6 rounded-lg shadow-md h-full">
        <h3 class="text-xl font-semibold mb-3 text-primary-600">{title}</h3>
        <p class="text-textcolor-950"><slot /></p>
    </div>
</div>
