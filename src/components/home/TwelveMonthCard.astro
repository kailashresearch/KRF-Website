---
interface Props {
  index: string;
  title: string;
}

const { index, title } = Astro.props;
---

<div class="bg-white p-5 rounded-lg shadow-md border-l-4 border-primary-800 transform transition-transform hover:scale-105">
    <div class="flex items-center mb-3">
        <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center mr-3">
            <span class="text-primary-600 font-semibold">{index}</span>
        </div>
        <h4 class="font-semibold text-primary-800 text-lg">{title}</h4>
    </div>
    <p class="text-textcolor-950"><slot /></p>
</div>
